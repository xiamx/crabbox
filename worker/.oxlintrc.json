{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "deny",
    "perf": "deny",
    "suspicious": "deny"
  },
  "env": {
    "builtin": true,
    "es2026": true,
    "node": true,
    "vitest": true,
    "worker": true
  },
  "ignorePatterns": ["dist/**", "dist-cloudflare/**", "node_modules/**", "public/portal/assets/**"],
  "options": {
    "denyWarnings": true,
    "maxWarnings": 0,
    "reportUnusedDisableDirectives": "deny"
  },
  "plugins": ["typescript", "unicorn", "import", "vitest", "promise", "node"]
}
