{
  "name": "@openclaw/crabbox-plugin",
  "version": "0.14.0",
  "description": "OpenClaw plugin for running Crabbox remote testbox workflows",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.25"
    }
  },
  "scripts": {
    "cloudflare:deploy-smoke": "scripts/deploy-cloudflare-smoke.sh",
    "check": "node --check index.js && node --test index.test.js scripts/*.test.js",
    "docs:check": "node scripts/check-command-docs.mjs && node scripts/check-docs-links.mjs && node scripts/build-docs-site.mjs",
    "live:auth": "CRABBOX_LIVE=1 scripts/live-auth-smoke.sh",
    "test": "node --test index.test.js scripts/*.test.js"
  },
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
